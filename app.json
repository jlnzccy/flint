{
  "expo": {
    "name": "Flint",
    "slug": "flint",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "flint",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "package": "com.flint.app",
      "adaptiveIcon": {
        "backgroundColor": "#171210",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#171210",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#ff6b35"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "buildArchs": [
              "arm64-v8a"
            ]
          }
        }
      ],
      "expo-localization",
      "react-native-audio-api",
      [
        "expo-audio",
        {
          "recordAudioAndroid": false,
          "enableBackgroundPlayback": false
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Flint to use the camera to scan routine QR codes."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Flint to access your photos to save routine ticket stubs.",
          "savePhotosPermission": "Allow Flint to save routine ticket stubs to your library."
        }
      ],
      "./plugins/with-page-transition",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
